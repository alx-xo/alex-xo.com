---
import Main from "@/layouts/Main.astro";
import Card from "@/components/ui/Card.astro";
---

<Main
  page={{
    title: "Alex ・ FrontEnd Engineer & Designer",
    description:
      "Frontend engineer and designer based in SF. I build interfaces that are fast, usable, and enjoyable.",
    navActive: "home",
  }}
>
  <div
    class="flex justify-center items-center w-full min-h-[calc(100dvh-82px)] px-6"
  >
    <Card title="about">
      <h2 class="text-xl font-black italic">
        Hi, I’m Alex and I like to make things
      </h2>

      <p class="text-base font-medium not-italic">
        Frontend engineer and sometimes designer in San Francisco. I care about
        the interactions, typography, and the stuff that makes using the web
        enjoyable.
        {" "}
        <a href="/work/" class="underline underline-offset-2">View my work</a>
      </p>

      <p class="text-base font-medium not-italic">
        I also dabble in design, block printing, and painting
      </p>
    </Card>
  </div>
</Main>
