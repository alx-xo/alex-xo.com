---
const { navActive } = Astro.props;

const navItems = [
  { name: "home", href: "/" },
  { name: "work", href: "/work/" },
  { name: "contact", href: "/contact/" },
];
---

<header
  class="bg-primary w-full flex justify-center items-center sticky top-0 z-50"
>
  <nav class="p-5">
    <ul
      class="list-none flex flex-row items-center gap-6 italic text-[28px] font-black"
    >
      {
        navItems.map((item) => {
          const isActive = item.name === navActive;
          return (
            <li class="group cursor-pointer">
              <a
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "group-hover:text-secondary",
                  { "text-primary-foreground": !isActive },
                  { "text-secondary": isActive },
                ]}
                href={item.href}
              >
                {item.name}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>
